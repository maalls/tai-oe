[Unit]
Description=TaiOe Frontend (Vite)
After=network-online.target taioe-backend.service
Wants=network-online.target taioe-backend.service

[Service]
Type=simple
User=malo
Group=malo
WorkingDirectory=/home/malo/tai-oe/front
Environment=NODE_ENV=development
Environment=PATH=/home/malo/.nvm/versions/node/v22.22.2/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin
ExecStart=/home/malo/.nvm/versions/node/v22.22.2/bin/npm run dev -- --host 0.0.0.0 --port 5173

Restart=always
RestartSec=5
TimeoutStartSec=120
KillSignal=SIGTERM

StandardOutput=journal
StandardError=journal
SyslogIdentifier=taioe-frontend

[Install]
WantedBy=multi-user.target
